# ──────────────────────────────────────────────────────────
# Flinq — environment variables template
# Copy to .env and fill in the values for your installation.
# ──────────────────────────────────────────────────────────

# Application
FLINQ_ENV=dev                              # dev | prod
FLINQ_LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
FLINQ_SECRET_KEY=change-me-in-production   # used for session cookies; generate with: openssl rand -hex 32
# Local data directory (dictionary dump cache). Defaults to <repo>/data.
#FLINQ_DATA_DIR=

# Database (Postgres)
POSTGRES_USER=flinq
POSTGRES_PASSWORD=flinq
POSTGRES_DB=flinq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
FLINQ_DATABASE_URL=postgresql+asyncpg://flinq:flinq@postgres:5432/flinq

# Redis
FLINQ_REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────
# LLM provider (OpenAI-compatible) — see ADR-0003
# ──────────────────────────────────────────────────────────
FLINQ_LLM_ENABLED=false
FLINQ_LLM_BASE_URL=https://api.openai.com/v1
FLINQ_LLM_API_KEY=
FLINQ_LLM_MODEL=gpt-4o-mini
FLINQ_LLM_TIMEOUT_SECONDS=30

# ──────────────────────────────────────────────────────────
# OCR service (optional, external) — see architecture §5.1
# ──────────────────────────────────────────────────────────
FLINQ_OCR_ENABLED=false
FLINQ_OCR_BASE_URL=
FLINQ_OCR_API_KEY=